		<script>
			let token = "";
			let role = "";
			let usernameLogged = "";

			const loginBtn = document.getElementById("loginBtn");
			const loginResult = document.getElementById("loginResult");

			const goRegisterBtn = document.getElementById("goRegisterBtn");
			const goSearchBtn = document.getElementById("goSearchBtn");
			const logoutBtn = document.getElementById("logoutBtn");

			const backFromRegisterBtn = document.getElementById("backFromRegisterBtn");
			const backFromSearchBtn = document.getElementById("backFromSearchBtn");

			const uploadForm = document.getElementById("uploadForm");
			const uploadResult = document.getElementById("uploadResult");

			const searchBtn = document.getElementById("searchBtn");
			const resultsDiv = document.getElementById("results");
			const userInfo = document.getElementById("userInfo");

			function showScreen(screenId) {
			document.querySelectorAll(".screen").forEach(screen => {
			screen.classList.remove("active");
			});
			document.getElementById(screenId).classList.add("active");
			}

			function resetRegisterForm() {
			document.getElementById("quarto").value = "";
			document.getElementById("photo").value = "";
			}

			function setUserInfo() {
			// replaced template literal with concatenation to avoid backticks
			userInfo.textContent = "Utilizador: " + usernameLogged + " | Perfil: " + role;
			}

			function clearElement(element) {
			while (element.firstChild) {
			element.removeChild(element.firstChild);
			}
			}

			function createMessage(type, text) {
			const p = document.createElement("p");
			p.className = type;
			p.textContent = text;
			return p;
			}

			async function loadProtectedImage(imgElement, url, token) {
			const res = await fetch(url, {
			headers: {
			"Authorization": "Bearer " + token
			}
			});

			if (!res.ok) {
			throw new Error("Erro ao carregar imagem");
			}

			const blob = await res.blob();
			const objectUrl = URL.createObjectURL(blob);
			imgElement.src = objectUrl;
			}

			function renderSearchResults(results) {
			clearElement(resultsDiv);

			results.forEach(r => {
			const card = document.createElement("div");
			card.className = "result-card";

			const quartoLabel = document.createElement("strong");
			quartoLabel.textContent = "Quarto:";
			card.appendChild(quartoLabel);
			card.appendChild(document.createTextNode(" "));

			const quartoValue = document.createElement("span");
			quartoValue.style.fontSize = "18px";
			quartoValue.textContent = r.quarto;
			card.appendChild(quartoValue);
			card.appendChild(document.createElement("br"));

			const macLabel = document.createElement("strong");
			macLabel.textContent = "MAC:";
			card.appendChild(macLabel);
			card.appendChild(document.createTextNode(" "));

			const macValue = document.createElement("span");
			macValue.style.fontFamily = "monospace";
			macValue.textContent = r.mac;
			card.appendChild(macValue);
			card.appendChild(document.createElement("br"));

			if (r.foto) {
			const img = document.createElement("img");
			img.alt = "Foto do AP";

			loadProtectedImage(img, r.foto, token).catch(() => {
			img.remove();
			card.appendChild(createMessage("info", "Não foi possível carregar a imagem."));
			});

			card.appendChild(img);
			}

			if (role === "admin") {
			const deleteBtn = document.createElement("button");
			deleteBtn.className = "danger";
			deleteBtn.textContent = "Apagar Registo";
			deleteBtn.addEventListener("click", () => deleteAP(r.id));
			card.appendChild(deleteBtn);
			}

			resultsDiv.appendChild(card);
			});
			}

			loginBtn.addEventListener("click", async () => {
			const username = document.getElementById("username").value.trim();
			const password = document.getElementById("password").value;

			clearElement(loginResult);

			try {
			const res = await fetch("/auth/login", {
			method: "POST",
			headers: {
			"Content-Type": "application/json"
			},
			body: JSON.stringify({ username, password })
			});

			const data = await res.json();

			if (res.ok) {
			token = data.access_token;
			role = data.role || "";
			usernameLogged = username;

			setUserInfo();
			showScreen("menuScreen");
			} else {
			loginResult.appendChild(
			createMessage("error", data.detail || "Login inválido")
			);
			}
			} catch (error) {
			loginResult.appendChild(
			createMessage("error", "Erro de ligação ao servidor.")
			);
			}
			});

			goRegisterBtn.addEventListener("click", () => {
			clearElement(uploadResult);
			showScreen("registerScreen");
			});

			goSearchBtn.addEventListener("click", () => {
			clearElement(resultsDiv);
			showScreen("searchScreen");
			});

			backFromRegisterBtn.addEventListener("click", () => {
			showScreen("menuScreen");
			});

			backFromSearchBtn.addEventListener("click", () => {
			showScreen("menuScreen");
			});

			logoutBtn.addEventListener("click", () => {
			token = "";
			role = "";
			usernameLogged = "";

			document.getElementById("username").value = "";
			document.getElementById("password").value = "";
			document.getElementById("searchQuarto").value = "";
			document.getElementById("searchMac").value = "";

			clearElement(loginResult);
			clearElement(uploadResult);
			clearElement(resultsDiv);

			showScreen("loginScreen");
			});

			uploadForm.addEventListener("submit", async (e) => {
			e.preventDefault();

			const quarto = document.getElementById("quarto").value.trim();
			const photo = document.getElementById("photo").files[0];

			clearElement(uploadResult);

			if (!photo) {
			uploadResult.appendChild(
			createMessage("error", "Seleciona uma foto.")
			);
			return;
			}

			const formData = new FormData();
			formData.append("quarto", quarto);
			formData.append("photo", photo);

			try {
			const res = await fetch("/aps/upload", {
			method: "POST",
			headers: {
			"Authorization": "Bearer " + token
			},
			body: formData
			});

			const data = await res.json();

			if (res.ok && data.success) {
			uploadResult.appendChild(
			createMessage("success", "MAC " + data.mac + " registado no quarto " + data.quarto + ".")
			);
			resetRegisterForm();
			} else {
			uploadResult.appendChild(
			createMessage("error", data.message || data.detail || "Erro no registo.")
			);
			}
			} catch (error) {
			uploadResult.appendChild(
			createMessage("error", "Erro de ligação ao servidor.")
			);
			}
			});

			searchBtn.addEventListener("click", async () => {
			const quarto = document.getElementById("searchQuarto").value.trim();
			const mac = document.getElementById("searchMac").value.trim();

			let url = "/aps/search?";
			if (quarto) url += 'quarto=' + encodeURIComponent(quarto) + '&';
			if (mac) url += 'mac=' + encodeURIComponent(mac) + '&';

			try {
			const res = await fetch(url, {
			headers: {
			"Authorization": "Bearer " + token
			}
			});

			const data = await res.json();

			if (!res.ok) {
			clearElement(resultsDiv);
			resultsDiv.appendChild(
			createMessage("error", data.detail || "Erro na pesquisa.")
			);
			return;
			}

			if (!data.results || data.results.length === 0) {
			clearElement(resultsDiv);
			resultsDiv.appendChild(
			createMessage("info", "Nenhum AP encontrado.")
			);
			return;
			}

			renderSearchResults(data.results);
			} catch (error) {
			clearElement(resultsDiv);
			resultsDiv.appendChild(
			createMessage("error", "Erro de ligação ao servidor.")
			);
			}
			});

			async function deleteAP(id) {
			const confirmar = confirm('Queres apagar o registo com ID ' + id + '?');
			if (!confirmar) return;

			try {
			const res = await fetch('/aps/' + id, {
			method: "DELETE",
			headers: {
			"Authorization": "Bearer " + token
			}
			});

			const data = await res.json();

			if (res.ok) {
			alert(data.message || "Registo apagado com sucesso.");
			searchBtn.click();
			} else {
			alert(data.detail || "Erro ao apagar registo.");
			}
			} catch (error) {
			alert("Erro de ligação ao servidor.");
			}
			}
		</script>
